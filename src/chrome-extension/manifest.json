{
  "manifest_version": 3,
  "name": "Aixis AI Audit Recorder",
  "version": "3.0.0",
  "description": "AI監査プラットフォーム — テスト記録Chrome拡張。プロトコルテストの実行、タイマー計測、スクリーンショット収集を行います。",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "offscreen",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Aixis AI Audit Recorder"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
