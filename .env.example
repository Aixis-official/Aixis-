# Aixis Platform Configuration
DATABASE_URL=sqlite+aiosqlite:///./aixis.db
SECRET_KEY=your-secret-key-here
DEBUG=true

# SMTP Settings (Gmail example)
# For Gmail: enable 2FA, then create App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@aixis.jp
SMTP_TO=info@aixis.jp

# Admin seed
ADMIN_EMAIL=admin@aixis.jp
ADMIN_PASSWORD=changeme123

# AI Browser Agent (Haiku Vision)
# Anthropic APIキー: https://console.anthropic.com/ で取得
ANTHROPIC_API_KEY=
# モデル（デフォルト: claude-haiku-4-5-20251001）
# AI_AGENT_MODEL=claude-haiku-4-5-20251001
