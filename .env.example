# Aixis Platform Configuration
AIXIS_DATABASE_URL=sqlite+aiosqlite:///./aixis.db
AIXIS_SECRET_KEY=your-secret-key-here
AIXIS_DEBUG=true

# SMTP Settings (Gmail example)
# For Gmail: enable 2FA, then create App Password at https://myaccount.google.com/apppasswords
AIXIS_SMTP_HOST=smtp.gmail.com
AIXIS_SMTP_PORT=587
AIXIS_SMTP_USER=your-gmail@gmail.com
AIXIS_SMTP_PASSWORD=your-app-password
AIXIS_SMTP_FROM=noreply@aixis.jp
AIXIS_SMTP_TO=info@aixis.jp

# Admin seed
AIXIS_ADMIN_EMAIL=admin@aixis.jp
AIXIS_ADMIN_PASSWORD=changeme123

# AI Browser Agent (Haiku Vision)
# Anthropic APIキー: https://console.anthropic.com/ で取得
AIXIS_ANTHROPIC_API_KEY=
# モデル（デフォルト: claude-haiku-4-5-20251001）
# AIXIS_AI_AGENT_MODEL=claude-haiku-4-5-20251001
